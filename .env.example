SECRET_KEY=replace-with-a-long-random-value
ENVIRONMENT=development
APP_DOMAIN=localhost
ACME_EMAIL=admin@example.com
ADMIN_EMAILS=["admin@example.com"]
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BACKEND=memory
SECURITY_HEADERS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=semantic-research-assistant
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
MAX_UPLOAD_MB=50
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=research-documents
S3_REGION=us-east-1
FILE_SCAN_ENABLED=false
FILE_SCAN_COMMAND=clamscan --no-summary {path}
FILE_SCAN_TIMEOUT_SECONDS=30
OCR_ENABLED=false
OCR_MIN_TEXT_CHARS=200
OCR_COMMAND=tesseract {path} stdout -l {language}
OCR_LANGUAGE=eng
OCR_TIMEOUT_SECONDS=120
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
KEYWORD_CANDIDATE_LIMIT=80
VECTOR_CANDIDATE_MULTIPLIER=4
MIN_RELEVANCE_SCORE=0.05
CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]

# Use OpenAI for generation and optionally embeddings.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Default embeddings are local sentence-transformers.
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# For fully local generation, set LLM_PROVIDER=ollama and enable an ollama service/profile.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
